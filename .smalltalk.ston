SmalltalkCISpec {
  #loading : [
    SCIMetacelloLoadSpec {
      #baseline : 'PCRE2',
      #directory : 'src',
      #platforms : [ #pharo ]
    }
  ],
  #testing : {
    #packages : [
      'PCRE2-Tests',
      'PCRE2-Tools-Tests'
    ],
    #coverage : {
      #packages : [ 'PCRE2', 'PCRE2-Tools' ],
      #format : #lcov
    }
  }
}