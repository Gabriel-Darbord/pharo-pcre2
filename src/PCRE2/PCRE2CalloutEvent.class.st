"
I am a snapshot of a runtime PCRE2 callout.

PCRE2 creates me while a match is running at an explicit callout such as (?C1) or a generated automatic callout. I copy the numeric match state and callout strings out of the native callout block so clients can safely keep events after the callback returns.

Offsets are raw PCRE2 code-unit offsets in the prepared subject and pattern for the matcher width that produced the event. They are intentionally not translated here because a debugger may need the exact native positions first, then decide how and when to map them back to Pharo character indexes.

For debugger-style consumers, `eventKind` classifies the event as a start match, normal progress, or backtrack step, and `isAutomatic` identifies events generated by `PCRE2_AUTO_CALLOUT`.
"
Class {
	#name : 'PCRE2CalloutEvent',
	#superclass : 'Object',
	#instVars : [
		'version',
		'number',
		'captureTop',
		'captureLast',
		'offsets',
		'mark',
		'subjectLength',
		'startMatch',
		'currentPosition',
		'patternPosition',
		'nextItemLength',
		'stringOffset',
		'stringLength',
		'string',
		'flags'
	],
	#category : 'PCRE2',
	#package : 'PCRE2'
}

{ #category : 'instance creation' }
PCRE2CalloutEvent class >> fromCalloutBlock: anExternalAddress [

	^ self fromCalloutBlock: anExternalAddress codeUnitWidth: 8
]

{ #category : 'instance creation' }
PCRE2CalloutEvent class >> fromCalloutBlock: anExternalAddress codeUnitWidth: codeUnitWidth [

	^ self new
		  initializeFromCalloutBlock: anExternalAddress
		  codeUnitWidth: codeUnitWidth
]

{ #category : 'private' }
PCRE2CalloutEvent class >> offsetsFrom: anExternalAddress count: count [

	| values wordSize |
	(anExternalAddress isNil or: [ anExternalAddress isNull ]) ifTrue: [
		^ #(  ) ].
	values := Array new: count.
	wordSize := ExternalAddress wordSize.
	1 to: count do: [ :index |
		values
			at: index
			put:
			(self sizeTFrom: anExternalAddress atOffset: wordSize * (index - 1)) ].
	^ values
]

{ #category : 'private' }
PCRE2CalloutEvent class >> sizeTFrom: anExternalAddress atOffset: structOffsetInBytes [
	"Read a PCRE2_SIZE field from a native callout struct. The ExternalAddress offset is measured in bytes."

	^ PCRE2CalloutSite
		  sizeTFrom: anExternalAddress
		  atOffset: structOffsetInBytes
]

{ #category : 'private' }
PCRE2CalloutEvent class >> stringFrom: anExternalAddress length: length [

	^ PCRE2CalloutSite stringFrom: anExternalAddress length: length
]

{ #category : 'private' }
PCRE2CalloutEvent class >> stringFrom: anExternalAddress length: length codeUnitWidth: codeUnitWidth [

	^ PCRE2CalloutSite
		  stringFrom: anExternalAddress
		  length: length
		  codeUnitWidth: codeUnitWidth
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> captureLast [

	^ captureLast
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> captureTop [

	^ captureTop
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> currentPosition [
	"Answer the current subject position as a zero-based PCRE2 code-unit offset."

	^ currentPosition
]

{ #category : 'testing' }
PCRE2CalloutEvent >> eventKind [
	"Answer the coarse debugger step kind represented by this callout event."

	self isBacktrack ifTrue: [ ^ #backtrack ].
	self isStartMatch ifTrue: [ ^ #startMatch ].
	^ #progress
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> flags [

	^ flags
]

{ #category : 'testing' }
PCRE2CalloutEvent >> hasString [

	^ string notNil
]

{ #category : 'initialization' }
PCRE2CalloutEvent >> initializeFromCalloutBlock: anExternalAddress [

	^ self initializeFromCalloutBlock: anExternalAddress codeUnitWidth: 8
]

{ #category : 'initialization' }
PCRE2CalloutEvent >> initializeFromCalloutBlock: anExternalAddress codeUnitWidth: codeUnitWidth [

	| offsetVectorOffset pointerOffset sizeOffset wordSize |
	wordSize := ExternalAddress wordSize.
	offsetVectorOffset := 16.
	sizeOffset := offsetVectorOffset + (3 * wordSize).

	version := anExternalAddress uint32AtOffset: 0.
	number := anExternalAddress uint32AtOffset: 4.
	captureTop := anExternalAddress uint32AtOffset: 8.
	captureLast := anExternalAddress uint32AtOffset: 12.
	offsets := self class offsetsFrom: (anExternalAddress pointerAtOffset: offsetVectorOffset) count: captureTop * 2.
	mark := PCRE2CalloutSite
		        zeroTerminatedStringFrom: (anExternalAddress pointerAtOffset: offsetVectorOffset + wordSize)
		        codeUnitWidth: codeUnitWidth.
	subjectLength := self class sizeTFrom: anExternalAddress atOffset: sizeOffset.
	startMatch := self class sizeTFrom: anExternalAddress atOffset: sizeOffset + wordSize.
	currentPosition := self class sizeTFrom: anExternalAddress atOffset: sizeOffset + (2 * wordSize).
	patternPosition := self class sizeTFrom: anExternalAddress atOffset: sizeOffset + (3 * wordSize).
	nextItemLength := self class sizeTFrom: anExternalAddress atOffset: sizeOffset + (4 * wordSize).
	stringOffset := self class sizeTFrom: anExternalAddress atOffset: sizeOffset + (5 * wordSize).
	stringLength := self class sizeTFrom: anExternalAddress atOffset: sizeOffset + (6 * wordSize).
	pointerOffset := sizeOffset + (7 * wordSize).
	string := self class
		          stringFrom: (anExternalAddress pointerAtOffset: pointerOffset)
		          length: stringLength
		          codeUnitWidth: codeUnitWidth.
	flags := anExternalAddress uint32AtOffset: pointerOffset + wordSize
]

{ #category : 'testing' }
PCRE2CalloutEvent >> isAutomatic [
	"Answer whether this event came from PCRE2_AUTO_CALLOUT rather than an explicit (?C...) item."

	^ number = PCRE2 automaticCalloutNumber and: [ string isNil ]
]

{ #category : 'testing' }
PCRE2CalloutEvent >> isBacktrack [

	^ (flags bitAnd: PCRE2 calloutBacktrack) ~~ 0
]

{ #category : 'testing' }
PCRE2CalloutEvent >> isStartMatch [

	^ (flags bitAnd: PCRE2 calloutStartMatch) ~~ 0
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> mark [

	^ mark
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> nextItemLength [
	"Answer the length of the next pattern item in PCRE2 code units."

	^ nextItemLength
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> number [

	^ number
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> offsets [
	"Answer raw zero-based PCRE2 code-unit ovector offsets visible at this callout."

	^ offsets
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> offsetsAt: pairIndex [
	"Answer the requested zero-based {start. exclusiveEnd} PCRE2 code-unit ovector pair."

	| index |
	index := 2 * (pairIndex - 1).
	^ {
		  (offsets at: index + 1).
		  (offsets at: index + 2) }
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> patternPosition [
	"Answer the current pattern position as a zero-based PCRE2 code-unit offset."

	^ patternPosition
]

{ #category : 'printing' }
PCRE2CalloutEvent >> printOn: aStream [

	super printOn: aStream.
	aStream
		nextPut: $(;
		print: patternPosition;
		nextPutAll: ', ';
		print: currentPosition;
		nextPutAll: ', ';
		print: number.
	string ifNotNil: [
		aStream
			nextPutAll: ', ';
			print: string ].
	aStream nextPut: $)
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> startMatch [
	"Answer the subject start position for this match attempt as a zero-based PCRE2 code-unit offset."

	^ startMatch
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> string [

	^ string
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> stringLength [
	"Answer the callout string length in PCRE2 code units."

	^ stringLength
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> stringOffset [
	"Answer the callout string's pattern position as a zero-based PCRE2 code-unit offset."

	^ stringOffset
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> subjectLength [
	"Answer the prepared subject length in PCRE2 code units."

	^ subjectLength
]

{ #category : 'accessing' }
PCRE2CalloutEvent >> version [

	^ version
]
